root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{kt,kts}]
max_line_length = 120
# Disable filename rule — entry point files (main.kt) use Kotlin convention
ktlint_standard_filename = disabled
# Allow PascalCase for @Composable functions (Compose naming convention)
ktlint_function_naming_ignore_when_annotated_with = Composable
