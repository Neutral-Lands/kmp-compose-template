# Nouri — Web (Wasm) environment variables
# Copy this file to .env.local and fill in the values from 1Password → Nouri vault.
# Never commit .env.local, .env.dev, or .env.prod.
#
# Usage:
#   source .env.local && ./gradlew :shared:wasmJsBrowserDevelopmentRun
#
# The values are injected at build time via webpack DefinePlugin (shared/webpack.config.d/env.js).

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
